@model List<JobPortal.Models.Application>
@{
    ViewData["Title"] = "طلباتي";
    var filterStatus = ViewBag.FilterStatus as string;
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-file-alt me-2 text-primary"></i>طلباتي (@Model.Count)</h1>
    </div>
</div>

<div class="container pb-5">
    <!-- Filter Tabs -->
    <div class="d-flex gap-2 flex-wrap mb-4">
        <a asp-action="MyApplications" class="btn btn-sm @(filterStatus == null ? "btn-primary" : "btn-outline-secondary")">الكل (@Model.Count)</a>
        @foreach (var s in Enum.GetValues<JobPortal.Models.ApplicationStatus>())
        {
            var count = Model.Count(a => a.Status == s);
            <a asp-action="MyApplications" asp-route-status="@s"
               class="btn btn-sm @(filterStatus == s.ToString() ? "btn-primary" : "btn-outline-secondary")">
                @s.GetDisplayName() (@count)
            </a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon fs-1">📋</div>
            <h5 class="fw-bold">لا توجد طلبات</h5>
            <p class="text-muted">لم تقدم على أي وظيفة بعد. ابدأ بتصفح الفرص المتاحة!</p>
            <a asp-controller="Jobs" asp-action="Index" class="btn btn-primary">تصفح الوظائف</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var app in Model)
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-body p-4">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <div class="company-logo">
                                        @(app.Job?.Employer?.CompanyName?.Substring(0,1)?.ToUpper() ?? "C")
                                    </div>
                                </div>
                                <div class="col">
                                    <h6 class="fw-bold mb-1">
                                        <a asp-controller="Jobs" asp-action="Details" asp-route-id="@app.JobId" class="text-decoration-none text-dark">
                                            @app.Job?.Title
                                        </a>
                                    </h6>
                                    <div class="text-muted small">
                                        <i class="fas fa-building me-1"></i>@app.Job?.Employer?.CompanyName
                                        <span class="mx-2">•</span>
                                        <i class="fas fa-map-marker-alt me-1"></i>@app.Job?.Location
                                    </div>
                                    @if (!string.IsNullOrEmpty(app.EmployerNotes))
                                    {
                                        <div class="mt-2 p-2 rounded-2 small" style="background:#f0f9ff; border-right:3px solid #0ea5e9; color:#0c4a6e;">
                                            <i class="fas fa-comment me-1"></i>ملاحظة صاحب العمل: @app.EmployerNotes
                                        </div>
                                    }
                                </div>
                                <div class="col-auto text-center">
                                    <span class="status-badge status-@app.Status.ToString().ToLower() d-block mb-2">
                                        @app.Status.GetDisplayName()
                                    </span>
                                    <div class="text-muted small">
                                        <i class="far fa-calendar me-1"></i>@app.AppliedAt.ToString("dd/MM/yyyy")
                                    </div>
                                    @if (app.LastUpdated.HasValue)
                                    {
                                        <div class="text-muted small">آخر تحديث: @app.LastUpdated.Value.ToString("dd/MM/yyyy")</div>
                                    }
                                </div>
                                <div class="col-auto">
                                    <div class="d-flex flex-column gap-2">
                                        @if (!string.IsNullOrEmpty(app.CvPath))
                                        {
                                            <a href="@app.CvPath" target="_blank" class="btn btn-sm btn-outline-secondary">
                                                <i class="fas fa-file-pdf me-1 text-danger"></i>السيرة الذاتية
                                            </a>
                                        }
                                        @if (app.Status == JobPortal.Models.ApplicationStatus.Pending || app.Status == JobPortal.Models.ApplicationStatus.Reviewed)
                                        {
                                            <form method="post" asp-action="WithdrawApplication" asp-route-id="@app.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('هل أنت متأكد من سحب الطلب؟')">
                                                    <i class="fas fa-undo me-1"></i>سحب
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
