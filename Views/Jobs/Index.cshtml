@model JobPortal.ViewModels.JobSearchViewModel
@using JobPortal.Models
@{
    ViewData["Title"] = "تصفح الوظائف";
}

<div class="page-header">
    <div class="container">
        <h1 class="mb-2"><i class="fas fa-search me-2 text-primary"></i>تصفح الوظائف</h1>
        <p class="text-muted mb-0">@Model.TotalCount وظيفة متاحة @(string.IsNullOrEmpty(Model.Keyword) ? "" : $"نتائج البحث عن \"{Model.Keyword}\"")</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">

        <!-- Sidebar Filters -->
        <div class="col-lg-3">
            <div class="filter-sidebar">
                <form method="get" id="filterForm">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0"><i class="fas fa-filter me-2"></i>تصفية النتائج</h6>
                        <a asp-action="Index" class="text-danger small text-decoration-none">مسح الكل</a>
                    </div>

                    <!-- Keyword -->
                    <div class="mb-3">
                        <input type="text" name="keyword" class="form-control" placeholder="🔍 كلمة مفتاحية..." value="@Model.Keyword">
                    </div>

                    <!-- Location -->
                    <div class="mb-3">
                        <label class="filter-section-title">الموقع</label>
                        <select name="location" class="form-select">
                            <option value="">كل المواقع</option>
                            @foreach (var loc in Model.Locations)
                            {
                                <option value="@loc" selected="@(Model.Location == loc)">@loc</option>
                            }
                        </select>
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <label class="filter-section-title">المجال</label>
                        <select name="category" class="form-select">
                            <option value="">كل المجالات</option>
                            @foreach (var cat in Model.Categories)
                            {
                                <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                            }
                        </select>
                    </div>

                    <!-- Job Type -->
                    <div class="mb-3">
                        <label class="filter-section-title">نوع الوظيفة</label>
                        @foreach (JobType jt in Enum.GetValues(typeof(JobType)))
                        {
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="radio" name="jobType" value="@((int)jt)"
                                       id="jt_@jt" @(Model.JobType == jt ? "checked" : "")>
                                <label class="form-check-label" for="jt_@jt">@jt.GetDisplayName()</label>
                            </div>
                        }
                    </div>

                    <!-- Experience -->
                    <div class="mb-3">
                        <label class="filter-section-title">مستوى الخبرة</label>
                        <select name="experienceLevel" class="form-select">
                            <option value="">كل المستويات</option>
                            @foreach (ExperienceLevel el in Enum.GetValues(typeof(ExperienceLevel)))
                            {
                                <option value="@((int)el)" selected="@(Model.ExperienceLevel == el)">@el.GetDisplayName()</option>
                            }
                        </select>
                    </div>

                    <!-- Remote -->
                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" name="isRemote" value="true" id="remoteCheck" @(Model.IsRemote == true ? "checked" : "")>
                            <label class="form-check-label" for="remoteCheck">عن بُعد فقط</label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search me-1"></i> بحث
                    </button>
                </form>
            </div>
        </div>

        <!-- Jobs List -->
        <div class="col-lg-9">
            <!-- Sort & Count -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-muted">
                    <strong class="text-dark">@Model.TotalCount</strong> وظيفة وجدت
                </span>
                <select class="form-select form-select-sm w-auto" onchange="changeSortOrder(this.value)">
                    <option value="newest" selected="@(Model.SortBy == "newest")">الأحدث أولاً</option>
                    <option value="salary" selected="@(Model.SortBy == "salary")">الراتب الأعلى</option>
                    <option value="popular" selected="@(Model.SortBy == "popular")">الأكثر مشاهدة</option>
                </select>
            </div>

            @if (!Model.Jobs.Any())
            {
                <div class="empty-state">
                    <div class="icon">🔍</div>
                    <h5 class="fw-bold">لا توجد وظائف مطابقة</h5>
                    <p class="text-muted">جرب تغيير معايير البحث أو مسح الفلاتر</p>
                    <a asp-action="Index" class="btn btn-primary">عرض كل الوظائف</a>
                </div>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var job in Model.Jobs)
                    {
                        <div class="col-12">
                            <div class="card job-card position-relative">
                                @if (job.IsFeatured)
                                {
                                    <span class="position-absolute" style="top:12px; left:12px; z-index:1">
                                        <span class="badge" style="background:linear-gradient(135deg,#f59e0b,#f97316);color:white;border-radius:50px;font-size:0.72rem">
                                            <i class="fas fa-star me-1"></i>مميز
                                        </span>
                                    </span>
                                }
                                <div class="card-body p-4">
                                    <div class="row align-items-center g-3">
                                        <div class="col-auto">
                                            <div class="company-logo">
                                                @(job.Employer?.CompanyName?.Substring(0, 1)?.ToUpper() ?? "C")
                                            </div>
                                        </div>
                                        <div class="col">
                                            <h5 class="job-title mb-1">
                                                <a asp-controller="Jobs" asp-action="Details" asp-route-id="@job.Id" class="text-decoration-none text-dark stretched-link">
                                                    @job.Title
                                                </a>
                                            </h5>
                                            <div class="text-muted mb-2">
                                                <i class="fas fa-building me-1"></i>@(job.Employer?.CompanyName ?? "—")
                                                <span class="mx-2">•</span>
                                                <i class="fas fa-map-marker-alt me-1"></i>@job.Location
                                                @if (job.IsRemote) { <span class="badge bg-success ms-1" style="font-size:0.7rem">عن بعد</span> }
                                            </div>
                                            <div class="d-flex flex-wrap gap-2">
                                                <span class="badge-tag">@job.JobType.GetDisplayName()</span>
                                                <span class="badge-tag purple">@job.ExperienceLevel.GetDisplayName()</span>
                                                <span class="badge-tag" style="background:#f0fdf4;color:#166534;border-color:#bbf7d0">@job.Category</span>
                                            </div>
                                        </div>
                                        <div class="col-auto text-end">
                                            @if (job.ShowSalary && (job.SalaryMin.HasValue || job.SalaryMax.HasValue))
                                            {
                                                <div class="salary-text mb-1">
                                                    @if (job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                                                    { @($"{job.SalaryMin:N0} - {job.SalaryMax:N0}") }
                                                    <small class="fw-normal">@job.SalaryCurrency</small>
                                                </div>
                                            }
                                            <div class="text-muted small">
                                                <i class="far fa-clock me-1"></i>
                                                @{
                                                    var diff = DateTime.Now - job.PostedAt;
                                                    if (diff.TotalDays < 1) { <text>اليوم</text> }
                                                    else if (diff.TotalDays < 7) { @($"منذ {(int)diff.TotalDays} أيام") }
                                                    else { @job.PostedAt.ToString("dd/MM/yyyy") }
                                                }
                                            </div>
                                            <div class="text-muted small">
                                                <i class="fas fa-eye me-1"></i>@job.ViewCount مشاهدة
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Pagination -->
                @if (Model.TotalCount > Model.PageSize)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (int p = 1; p <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); p++)
                            {
                                <li class="page-item @(p == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-keyword="@Model.Keyword"
                                       asp-route-location="@Model.Location"
                                       asp-route-category="@Model.Category"
                                       asp-route-page="@p">@p</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function changeSortOrder(val) {
    const url = new URL(window.location.href);
    url.searchParams.set('sortBy', val);
    window.location.href = url.toString();
}
</script>
}
