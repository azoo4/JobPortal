@model JobPortal.Models.Job

<div class="card job-card position-relative">
    <div class="card-body p-3">
        <div class="d-flex align-items-center gap-3">
            <div class="company-logo" style="width:44px;height:44px;font-size:1rem;">
                @(Model.Employer?.CompanyName?.Substring(0, 1)?.ToUpper() ?? "C")
            </div>
            <div class="flex-grow-1 min-w-0">
                <h6 class="job-title mb-0 text-truncate">
                    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-dark stretched-link">
                        @Model.Title
                    </a>
                </h6>
                <div class="company-name small">@(Model.Employer?.CompanyName ?? "—") • @Model.Location</div>
            </div>
            <div class="text-end flex-shrink-0">
                @if (Model.ShowSalary && Model.SalaryMin.HasValue)
                {
                    <div class="salary-text small">@Model.SalaryMin:N0 @Model.SalaryCurrency</div>
                }
                <span class="badge-tag mt-1 d-inline-block">@Model.JobType.GetDisplayName()</span>
            </div>
        </div>
    </div>
</div>
