@model JobPortal.Models.Job

<div class="card job-card h-100 position-relative">
    @if (Model.IsFeatured)
    {
        <span class="featured-ribbon"><i class="fas fa-star me-1"></i> مميز</span>
    }
    <div class="card-body p-4">
        <div class="d-flex align-items-start gap-3 mb-3">
            <div class="company-logo">
                @(Model.Employer?.CompanyName?.Substring(0, 1)?.ToUpper() ?? "C")
            </div>
            <div class="flex-grow-1">
                <h6 class="job-title mb-1">
                    <a asp-controller="Jobs" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-dark stretched-link">
                        @Model.Title
                    </a>
                </h6>
                <div class="company-name">@(Model.Employer?.CompanyName ?? "شركة غير محددة")</div>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mb-3">
            <span class="badge-tag">
                <i class="fas fa-map-marker-alt me-1"></i>@Model.Location
                @if (Model.IsRemote) { <span class="text-success"> • عن بعد</span> }
            </span>
            <span class="badge-tag @(Model.JobType == JobPortal.Models.JobType.FullTime ? "green" : Model.JobType == JobPortal.Models.JobType.Internship ? "orange" : "")">
                @Model.JobType.GetDisplayName()
            </span>
            <span class="badge-tag purple">@Model.ExperienceLevel.GetDisplayName()</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.Skills))
        {
            <div class="d-flex flex-wrap gap-1 mb-3">
                @foreach (var skill in Model.Skills.Split(',').Take(3))
                {
                    <span style="background:#f1f5f9; color:#475569; padding:2px 8px; border-radius:50px; font-size:0.75rem;">@skill.Trim()</span>
                }
            </div>
        }

        <div class="d-flex justify-content-between align-items-center">
            @if (Model.ShowSalary && (Model.SalaryMin.HasValue || Model.SalaryMax.HasValue))
            {
                <span class="salary-text">
                    <i class="fas fa-coins me-1"></i>
                    @if (Model.SalaryMin.HasValue && Model.SalaryMax.HasValue)
                    { @($"{Model.SalaryMin:N0} - {Model.SalaryMax:N0} {Model.SalaryCurrency}") }
                    else if (Model.SalaryMax.HasValue)
                    { @($"حتى {Model.SalaryMax:N0} {Model.SalaryCurrency}") }
                </span>
            }
            else
            {
                <span class="text-muted small">الراتب: يُحدد لاحقاً</span>
            }
            <span class="text-muted small">
                <i class="far fa-clock me-1"></i>
                @{
                    var diff = DateTime.Now - Model.PostedAt;
                    if (diff.TotalDays < 1) { <text>اليوم</text> }
                    else if (diff.TotalDays < 7) { @($"منذ {(int)diff.TotalDays} أيام") }
                    else { @Model.PostedAt.ToString("dd/MM/yyyy") }
                }
            </span>
        </div>
    </div>
</div>
