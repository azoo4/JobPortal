@{
    ViewData["Title"] = "الرئيسية";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var featuredJobs = ViewBag.FeaturedJobs as List<JobPortal.Models.Job> ?? new();
    var recentJobs = ViewBag.RecentJobs as List<JobPortal.Models.Job> ?? new();
    var categories = ViewBag.Categories as List<JobPortal.Models.ViewModels.CategoryItem>;
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="hero-badge">
                    <i class="fas fa-fire me-1"></i> المنصة الأولى للتوظيف في العالم العربي
                </div>
                
                <h1 class="hero-title mb-4">
                    اعثر على <span class="highlight">وظيفة أحلامك</span><br>
                    بين آلاف الفرص المتاحة
                </h1>
                <p class="text-muted mb-4" style="font-size:1.1rem; color:#94a3b8 !important;">
                    نربطك بأفضل الشركات والمواهب في العالم العربي. سواء كنت تبحث عن عمل أو تبحث عن موظفين.
                </p>

                <!-- Search Box -->
                <form asp-controller="Jobs" asp-action="Index" method="get">
                    <div class="hero-search-box mb-4">
                        <i class="fas fa-search text-muted px-2"></i>
                        <input type="text" name="keyword" placeholder="مسمى وظيفي، مهارة، أو شركة..." class="form-control border-0 shadow-none">
                        <input type="text" name="location" placeholder="الموقع..." class="form-control border-0 shadow-none" style="border-right: 1px solid #e2e8f0 !important;">
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill">
                            <i class="fas fa-search me-1"></i> ابحث
                        </button>
                    </div>
                </form>

                <div class="d-flex gap-2 flex-wrap">
                    <span class="text-muted small">الأكثر بحثاً:</span>
                    @foreach (var cat in new[] { "تطوير البرمجيات", "تصميم", "تحليل البيانات", "إدارة المشاريع" })
                    {
                        <a asp-controller="Jobs" asp-action="Index" asp-route-category="@cat" class="badge-tag">@cat</a>
                    }
                </div>
            </div>
            <div class="col-lg-5 mt-4 mt-lg-0">
                <div class="row g-3">
                    <div class="col-4">
                        <div class="hero-stat p-3 rounded-3" style="background: rgba(255,255,255,0.05)">
                            <div class="number">@ViewBag.TotalJobs+</div>
                            <div class="label">وظيفة متاحة</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="hero-stat p-3 rounded-3" style="background: rgba(255,255,255,0.05)">
                            <div class="number">@ViewBag.TotalEmployers+</div>
                            <div class="label">شركة موثوقة</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="hero-stat p-3 rounded-3" style="background: rgba(255,255,255,0.05)">
                            <div class="number">@ViewBag.TotalApplications+</div>
                            <div class="label">طلب مقدّم</div>
                        </div>
                    </div>
                </div>

                <!-- CTA Cards -->
                <div class="row g-3 mt-1">
                    <div class="col-6">
                        <a asp-controller="Account" asp-action="Register" asp-route-type="Applicant"
                           class="d-block p-3 rounded-3 text-decoration-none" style="background: rgba(37,99,235,0.15); border: 1px solid rgba(37,99,235,0.3)">
                            <i class="fas fa-user-tie fa-lg text-primary mb-2"></i>
                            <div class="text-white fw-bold">باحث عن عمل؟</div>
                            <div class="text-muted small">ابدأ مسيرتك</div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Account" asp-action="Register" asp-route-type="Employer"
                           class="d-block p-3 rounded-3 text-decoration-none" style="background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3)">
                            <i class="fas fa-building fa-lg text-purple mb-2" style="color:#a78bfa"></i>
                            <div class="text-white fw-bold">صاحب عمل؟</div>
                            <div class="text-muted small">وظّف الآن</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
@if (categories != null)
{
    <section class="py-5">
        <div class="container">
            <div class="text-center mb-4">
                <h2 class="section-title">تصفح حسب المجال</h2>
                <p class="section-subtitle">اختر المجال المناسب لمهاراتك وابدأ رحلتك المهنية</p>
            </div>
            <div class="row g-3">
                @{
                    var icons = new[] { "💻", "🎨", "📊", "📱", "🔒", "☁️", "🤖", "📋" };
                    int i = 0;
                }
                @foreach (var cat in categories)
                {
                    <div class="col-lg-3 col-md-4 col-6">
                        <a asp-controller="Jobs" asp-action="Index" asp-route-category="@cat.Category" class="text-decoration-none">
                            <div class="category-card">
                                <div class="category-icon">@(i < icons.Length ? icons[i] : "💼")</div>
                                <div class="fw-bold mt-2">@cat.Category</div>
                                <div class="text-muted small mt-1">@cat.Count وظيفة</div>
                            </div>
                        </a>
                    </div>
                    i++;
                }
            </div>
        </div>
    </section>
}

<!-- Featured Jobs -->
@if (featuredJobs.Any())
{
    <section class="py-5" style="background: white;">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="section-title">وظائف مميزة</h2>
                    <p class="section-subtitle">فرص مختارة بعناية من أبرز الشركات</p>
                </div>
                <a asp-controller="Jobs" asp-action="Index" class="btn btn-outline-primary">
                    عرض الكل <i class="fas fa-arrow-left me-1"></i>
                </a>
            </div>
            <div class="row g-4">
                @foreach (var job in featuredJobs)
                {
                    <div class="col-lg-4 col-md-6">
                        @await Html.PartialAsync("_JobCard", job)
                    </div>
                }
            </div>
        </div>
    </section>
}

<!-- Recent Jobs -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="section-title">أحدث الوظائف</h2>
                <p class="section-subtitle">وظائف نُشرت مؤخراً لا تفوّتها</p>
            </div>
            <a asp-controller="Jobs" asp-action="Index" class="btn btn-outline-primary">
                عرض الكل <i class="fas fa-arrow-left me-1"></i>
            </a>
        </div>
        <div class="row g-3">
            @foreach (var job in recentJobs)
            {
                <div class="col-lg-6">
                    @await Html.PartialAsync("_JobCardHorizontal", job)
                </div>
            }
        </div>
    </div>
</section>

<!-- How It Works -->
<section class="py-5" style="background: linear-gradient(135deg, #0f172a, #1e293b);">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title text-white">كيف تعمل المنصة؟</h2>
            <p class="text-muted">خطوات بسيطة للوصول إلى وظيفتك المثالية</p>
        </div>
        <div class="row g-4 text-center">
            @foreach (var step in new[] {
                new { icon = "fas fa-user-plus", title = "أنشئ حسابك", desc = "سجّل مجاناً في دقيقة واحدة فقط", color = "#60a5fa" },
                new { icon = "fas fa-search", title = "ابحث عن الوظيفة", desc = "تصفح آلاف الوظائف وصفّ النتائج", color = "#a78bfa" },
                new { icon = "fas fa-paper-plane", title = "قدّم طلبك", desc = "ارفع سيرتك الذاتية وأرسل طلبك بنقرة", color = "#34d399" },
                new { icon = "fas fa-handshake", title = "احصل على وظيفتك", desc = "تابع حالة طلبك وانتظر الرد", color = "#fbbf24" }
            })
            {
                <div class="col-lg-3 col-6">
                    <div class="p-4">
                        <div class="mb-3" style="width:70px; height:70px; border-radius:20px; margin:0 auto; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,0.05)">
                            <i class="@step.icon fa-xl" style="color: @step.color"></i>
                        </div>
                        <h6 class="text-white fw-bold mb-2">@step.title</h6>
                        <p class="text-muted small">@step.desc</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
