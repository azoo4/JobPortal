@model List<JobPortal.Models.ApplicationUser>
@{
    ViewData["Title"] = "إدارة المستخدمين";
    var filterRole = ViewBag.FilterRole as string;
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-users me-2 text-primary"></i>إدارة المستخدمين (@Model.Count)</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="d-flex gap-2 mb-4 flex-wrap">
        <a asp-action="Users" class="btn btn-sm @(filterRole == null ? "btn-primary" : "btn-outline-secondary")">الكل</a>
        <a asp-action="Users" asp-route-role="Employer" class="btn btn-sm @(filterRole == "Employer" ? "btn-primary" : "btn-outline-secondary")">أصحاب العمل</a>
        <a asp-action="Users" asp-route-role="Applicant" class="btn btn-sm @(filterRole == "Applicant" ? "btn-primary" : "btn-outline-secondary")">الباحثون</a>
        <a asp-action="Users" asp-route-role="Admin" class="btn btn-sm @(filterRole == "Admin" ? "btn-primary" : "btn-outline-secondary")">المدراء</a>
    </div>

    <div class="card">
        <div class="table-responsive">
            <table class="table table-modern align-middle mb-0">
                <thead>
                    <tr>
                        <th>المستخدم</th>
                        <th>البريد الإلكتروني</th>
                        <th>تاريخ التسجيل</th>
                        <th>الحالة</th>
                        <th>الإجراء</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="avatar-circle-sm">@(user.FullName.Substring(0,1).ToUpper())</div>
                                    <div>
                                        <div class="fw-bold small">@user.FullName</div>
                                        @if (!string.IsNullOrEmpty(user.CompanyName))
                                        { <div class="text-muted" style="font-size:0.75rem;">@user.CompanyName</div> }
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted small">@user.Email</td>
                            <td class="text-muted small">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <span class="badge @(user.IsActive ? "bg-success" : "bg-danger")" style="border-radius:50px;font-size:0.78rem;">
                                    @(user.IsActive ? "نشط" : "معطّل")
                                </span>
                            </td>
                            <td>
                                <form method="post" asp-action="ToggleUserStatus" asp-route-id="@user.Id" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-@(user.IsActive ? "danger" : "success")">
                                        @(user.IsActive ? "تعطيل" : "تفعيل")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
