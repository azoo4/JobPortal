@model JobPortal.ViewModels.EmployerProfileViewModel
@{
    ViewData["Title"] = "ملف الشركة";
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-building me-2 text-primary"></i>ملف الشركة</h1>
    </div>
</div>

<div class="container pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4 p-md-5">
                    <form method="post" enctype="multipart/form-data" asp-action="Profile">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <h6 class="fw-bold text-muted mb-3 border-bottom pb-2">معلومات الشركة</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label">اسم المسؤول *</label>
                                <input asp-for="FullName" class="form-control" />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label">رقم الهاتف</label>
                                <input asp-for="PhoneNumber" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CompanyName" class="form-label">اسم الشركة</label>
                                <input asp-for="CompanyName" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Industry" class="form-label">القطاع</label>
                                <select asp-for="Industry" class="form-select">
                                    <option value="">اختر القطاع</option>
                                    @foreach (var ind in new[] { "تكنولوجيا المعلومات", "تطوير البرمجيات", "التصميم والإبداع", "التسويق الرقمي", "المحاسبة والمالية", "الهندسة", "الرعاية الصحية", "التعليم", "التجزئة والبيع", "البناء والعقارات", "أخرى" })
                                    {
                                        <option value="@ind" selected="@(Model.Industry == ind)">@ind</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CompanyLocation" class="form-label">موقع الشركة</label>
                                <input asp-for="CompanyLocation" class="form-control" placeholder="المدينة، الدولة" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CompanyWebsite" class="form-label">الموقع الإلكتروني</label>
                                <input asp-for="CompanyWebsite" class="form-control" placeholder="https://www.company.com" />
                            </div>
                            <div class="col-12">
                                <label asp-for="CompanyDescription" class="form-label">نبذة عن الشركة</label>
                                <textarea asp-for="CompanyDescription" class="form-control" rows="5"
                                          placeholder="اكتب نبذة عن شركتك، مجالها، قيمها، وبيئة العمل..."></textarea>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LogoFile" class="form-label">
                                    <i class="fas fa-image me-1"></i>شعار الشركة
                                </label>
                                <input asp-for="LogoFile" class="form-control" type="file" accept="image/*" />
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-primary flex-grow-1">
                                <i class="fas fa-save me-2"></i>حفظ التغييرات
                            </button>
                            <a asp-action="Dashboard" class="btn btn-outline-secondary">إلغاء</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
