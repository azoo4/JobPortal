@model List<JobPortal.Models.Application>
@{
    ViewData["Title"] = "طلبات الوظيفة";
    var job = ViewBag.Job as JobPortal.Models.Job;
}

<div class="page-header">
    <div class="container">
        <h1><i class="fas fa-users me-2 text-primary"></i>طلبات: @job?.Title (@Model.Count)</h1>
        <p class="text-muted mb-0">@job?.Location • @job?.JobType.GetDisplayName()</p>
    </div>
</div>

<div class="container pb-5">
    <!-- Status summary -->
    <div class="row g-3 mb-4">
        @foreach (var s in Enum.GetValues<JobPortal.Models.ApplicationStatus>())
        {
            var count = Model.Count(a => a.Status == s);
            if (count > 0)
            {
                <div class="col-auto">
                    <div class="dashboard-card py-2 px-3 text-center">
                        <div class="fw-bold fs-5">@count</div>
                        <div class="text-muted small">@s.GetDisplayName()</div>
                    </div>
                </div>
            }
        }
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="icon fs-1">📭</div>
            <h5 class="fw-bold">لا توجد طلبات بعد</h5>
            <p class="text-muted">لم يتقدم أحد على هذه الوظيفة حتى الآن</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var app in Model)
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-body p-4">
                            <div class="row align-items-start g-3">
                                <div class="col-auto">
                                    <div class="avatar-circle-sm" style="width:48px;height:48px;font-size:1.2rem;">
                                        @(app.Applicant?.FullName?.Substring(0,1)?.ToUpper() ?? "?")
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                        <div>
                                            <h6 class="fw-bold mb-1">@app.Applicant?.FullName</h6>
                                            <div class="text-muted small">
                                                <i class="fas fa-envelope me-1"></i>@app.Applicant?.Email
                                                @if (!string.IsNullOrEmpty(app.Applicant?.PhoneNumber))
                                                {
                                                    <span class="mx-2">|</span>
                                                    <i class="fas fa-phone me-1"></i>@app.Applicant.PhoneNumber
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(app.Applicant?.CurrentPosition))
                                            {
                                                <div class="text-muted small mt-1">
                                                    <i class="fas fa-briefcase me-1"></i>@app.Applicant.CurrentPosition
                                                    @if (app.Applicant.YearsOfExperience.HasValue)
                                                    {
                                                        @($"— {app.Applicant.YearsOfExperience} سنوات خبرة")
                                                    }
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(app.Applicant?.Skills))
                                            {
                                                <div class="d-flex flex-wrap gap-1 mt-2">
                                                    @foreach (var skill in app.Applicant.Skills.Split(',').Take(5))
                                                    {
                                                        <span style="background:#eff6ff;color:#1d4ed8;padding:2px 8px;border-radius:50px;font-size:0.72rem;">@skill.Trim()</span>
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <span class="status-badge status-@app.Status.ToString().ToLower()">
                                            @app.Status.GetDisplayName()
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrEmpty(app.CoverLetter))
                                    {
                                        <div class="mt-3 p-3 rounded-3" style="background:#f8fafc; border-right:3px solid #2563eb;">
                                            <div class="text-muted small fw-bold mb-1">خطاب التقديم:</div>
                                            <p class="small mb-0">@app.CoverLetter</p>
                                        </div>
                                    }

                                    <!-- Update Status Form -->
                                    <form method="post" asp-controller="Employer" asp-action="UpdateApplicationStatus" class="mt-3 p-3 rounded-3" style="background:#f0f9ff;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ApplicationId" value="@app.Id" />
                                        <div class="row g-2 align-items-center">
                                            <div class="col-md-4">
                                                <select name="Status" class="form-select form-select-sm">
                                                    @foreach (var s in Enum.GetValues<JobPortal.Models.ApplicationStatus>())
                                                    {
                                                        <option value="@((int)s)" selected="@(app.Status == s)">@s.GetDisplayName()</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <input type="text" name="Notes" class="form-control form-control-sm" placeholder="ملاحظة للمتقدم (اختياري)" value="@app.EmployerNotes" />
                                            </div>
                                            <div class="col-md-2">
                                                <button type="submit" class="btn btn-primary btn-sm w-100">حفظ</button>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div class="col-auto text-end">
                                    <div class="d-flex flex-column gap-2">
                                        @if (!string.IsNullOrEmpty(app.CvPath))
                                        {
                                            <a href="@app.CvPath" target="_blank" class="btn btn-sm btn-outline-danger">
                                                <i class="fas fa-file-pdf me-1"></i>السيرة الذاتية
                                            </a>
                                        }
                                        <div class="text-muted" style="font-size:0.75rem;">
                                            <i class="far fa-calendar me-1"></i>@app.AppliedAt.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
